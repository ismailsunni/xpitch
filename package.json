{
  "name": "xpitch",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Front-end .fit football/minisoccer match analyzer",
  "scripts": {
    "dev": "vite",
    "build": "vite build && cp dist/index.html dist/404.html",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
