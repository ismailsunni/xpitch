    "vue": "^3.4.21",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "supabase": "^2.109.1",
    "typescript": "^5.4.5",
    "vite": "^5.2.10",
    "vitest": "^4.1.10",
    "vue-tsc": "^2.0.13"
  }
}
